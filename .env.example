# X (Twitter) OAuth 2.0 — Confidential client
# Get from https://developer.x.com → your app → Keys and tokens
X_OAUTH_CLIENT_ID=
X_OAUTH_CLIENT_SECRET=

# Postgres connection string
# Local dev example: postgresql://<user>@localhost:5432/agent_summer_dev
DATABASE_URL=

# Better Auth
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Contentful (Delivery API — read-only)
CONTENTFUL_SPACE_ID=
CONTENTFUL_ACCESS_TOKEN=
CONTENTFUL_PREVIEW_ACCESS_TOKEN=
CONTENTFUL_ENVIRONMENT=master
IS_PREVIEW_MODE_ENABLED=false

# Cloudflare image worker (rewrites images.ctfassets.net through this host)
NEXT_PUBLIC_WORKER_URL=https://cdn-assets.molandak.org
